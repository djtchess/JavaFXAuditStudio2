{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JavaFX Screen Analysis",
  "type": "object",
  "properties": {
    "screen": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "fxml": {"type": ["string", "null"]},
        "controller": {"type": ["string", "null"]},
        "structure": {"type": "array", "items": {"type": "object"}},
        "components": {"type": "array", "items": {"type": "object"}},
        "events": {"type": "array", "items": {"type": "object"}},
        "flows": {"type": "array", "items": {"type": "object"}},
        "dependencies": {"type": "array", "items": {"type": "object"}}
      },
      "required": ["name"]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "condition": {"type": "string"},
          "behavior": {"type": "string"},
          "impact_ui": {"type": ["string", "null"]},
          "confidence": {"type": "string", "enum": ["certain", "probable", "hypothetical"]},
          "sources": {"type": "array", "items": {"type": "string"}}
        },
        "required": ["id", "title", "behavior", "confidence"]
      }
    },
    "findings": {
      "type": "object",
      "properties": {
        "problems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "title": {"type": "string"},
              "severity": {"type": "string", "enum": ["faible", "moyenne", "forte", "critique"]},
              "location": {"type": "string"},
              "description": {"type": "string"},
              "impact": {"type": "string"},
              "recommendation": {"type": "string"},
              "tests_to_add": {"type": "array", "items": {"type": "string"}}
            },
            "required": ["id", "title", "severity", "location", "description"]
          }
        },
        "alerts": {"type": "array", "items": {"type": "string"}},
        "contradictions": {"type": "array", "items": {"type": "string"}},
        "unknowns": {"type": "array", "items": {"type": "string"}}
      }
    },
    "best_practices": {
      "type": "object",
      "properties": {
        "applicable": {"type": "array", "items": {"type": "object"}},
        "not_recommended_here": {"type": "array", "items": {"type": "object"}}
      }
    },
    "recommendations": {
      "type": "object",
      "properties": {
        "quick_wins": {"type": "array", "items": {"type": "object"}},
        "mid_term": {"type": "array", "items": {"type": "object"}},
        "structural": {"type": "array", "items": {"type": "object"}}
      }
    },
    "test_strategy": {
      "type": "object",
      "properties": {
        "priority_tests": {"type": "array", "items": {"type": "object"}},
        "unit_tests": {"type": "array", "items": {"type": "object"}},
        "controller_tests": {"type": "array", "items": {"type": "object"}},
        "integration_tests": {"type": "array", "items": {"type": "object"}},
        "preconditions": {"type": "array", "items": {"type": "string"}},
        "regression_focus": {"type": "array", "items": {"type": "string"}}
      }
    },
    "scores": {
      "type": "object",
      "properties": {
        "global": {"type": "number"},
        "readability": {"type": "number"},
        "maintainability": {"type": "number"},
        "separation_of_concerns": {"type": "number"},
        "robustness": {"type": "number"},
        "testability": {"type": "number"},
        "best_practices_alignment": {"type": "number"}
      }
    }
  },
  "required": ["screen"]
}
