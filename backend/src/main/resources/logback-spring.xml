<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="javaFxAuditStudio"/>

    <!--
        SECURITE (JAS-022) : les valeurs des credentials IA (CLAUDE_API_KEY, OPENAI_API_KEY)
        ne doivent jamais atteindre les logs. La garantie est portee par AiEnrichmentConfiguration
        qui ne logue que la presence/absence du credential, jamais sa valeur.
        Si un filtre Logback de masquage de secrets est requis ulterieurement, implémenter
        un MaskingPatternLayout sur les patterns contenant "api-key", "apiKey", "Bearer ".
    -->

    <!-- Appender CONSOLE commun a tous les profils -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%-5level app=${APP_NAME} corr=%X{correlationId:-no-corr} thread=%thread logger=%logger{36} msg=%msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Profil par defaut : INFO pour le package applicatif -->
    <springProfile name="default">
        <logger name="ff.ss.javaFxAuditStudio" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Profil dev : DEBUG pour le package applicatif, INFO pour Spring -->
    <springProfile name="dev">
        <logger name="ff.ss.javaFxAuditStudio" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <logger name="org.springframework" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
