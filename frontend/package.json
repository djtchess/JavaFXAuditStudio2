{
  "name": "javafx-audit-studio-front",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.spec.json",
    "lint": "npm run typecheck",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --coverage --coverage-reporters=json-summary --coverage-reporters=lcovonly --coverage-reporters=text-summary"
  },
  "dependencies": {
    "@angular/animations": "21.2.4",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/platform-browser": "21.2.4",
    "@angular/router": "21.2.4",
    "rxjs": "^7.8.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "@vitest/coverage-v8": "^4.1.0",
    "@types/node": "^22.13.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
