    <children>
        <Label text="Workflow d approbation" />
        <TextArea fx:id="decisionCommentArea" promptText="Commentaire de decision" />
        <Button fx:id="approveButton" text="Approuver" onAction="#onApprove" />
    </children>
</VBox>
