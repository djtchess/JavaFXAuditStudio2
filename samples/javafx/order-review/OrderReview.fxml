<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="app.ui.order.OrderReviewController" spacing="10">
    <children>
        <Label text="Order review" />
        <TextField fx:id="orderNumberField" />
        <TextField fx:id="customerSegmentField" />
        <CheckBox fx:id="complianceApprovedCheckBox" text="Compliance approved" />
        <TextArea fx:id="reviewCommentArea" />
        <Label fx:id="statusLabel" text="Pending" />
        <Button fx:id="validateButton" text="Validate" onAction="#onValidateOrder" />
        <Button fx:id="exportButton" text="Export" onAction="#onExportDecision" />
    </children>
</VBox>
